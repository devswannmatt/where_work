{{#if breadcrumbs.length}}
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      {{#each breadcrumbs}}
        <li>
          {{#if this.href}}
            <a href="{{this.href}}">{{this.label}}</a>
          {{else}}
            <span aria-current="page">{{this.label}}</span>
          {{/if}}
        </li>
      {{/each}}
    </ol>
  </nav>
{{/if}}
